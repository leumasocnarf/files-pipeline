{
  "realm": "microservices-realm",
  "enabled": true,
  "clients": [
    {
      "clientId": "gateway-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "GATEWAY_CLIENT_SECRET",
      "redirectUris": [
        "http://localhost/login/oauth2/code/keycloak",
        "http://localhost:9000/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:9000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600",
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost/*##http://localhost:9000/*"
      }
    },
    {
      "clientId": "ingest-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "INGEST_CLIENT_SECRET",
      "redirectUris": [],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultRoles": [
        "ingest:write",
        "ingest:read"
      ]
    },
    {
      "clientId": "processing-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "PROCESSING_CLIENT_SECRET",
      "redirectUris": [],
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultRoles": [
        "ingest:read"
      ]
    },
    {
      "clientId": "report-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "REPORT_CLIENT_SECRET",
      "redirectUris": [],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultRoles": [
        "report:read"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ingest:read"
      },
      {
        "name": "ingest:write"
      },
      {
        "name": "report:read"
      }
    ]
  },
  "users": [
    {
      "username": "test-admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ingest:read",
        "ingest:write",
        "report:read"
      ]
    }
  ]
}